AGENT_KEYPAIR=your_base58_private_key_here
VAULT_PROGRAM_ID=H6vbfTp6XwfFSHWtpzjZuyrx6bpnp8Rwt6bVZAUT6vZf
VAULT_ADDRESS=HMkL7zzAroE919esVY6HSMYzB2ejHM5m4A8JKCSrgBXR
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
SOLANA_RPC_URL=https://api.devnet.solana.com
DRIFT_ENV=devnet

# Treasury keypair (separate from AGENT_KEYPAIR) that funds pay.sh
# streaming micropayments. Without this set, payments are skipped entirely
# (better than a fake self-transfer). Generate once on devnet:
#   solana-keygen new --no-bip39-passphrase -o /tmp/treasury.json
#   solana airdrop 5 <treasury-pubkey> --url devnet
# Then paste the bs58 private key below.
FORNEX_TREASURY_KEYPAIR=

# Optional manual override for demo cycles. Set to LONG or SHORT to force the
# next cycle to execute that direction regardless of the AI consensus. Useful
# for guaranteeing a Drift transaction during live judging. Documented in
# DEMO_SCRIPT.md.
FORNEX_FORCE_DIRECTION=

# Single-cycle mode: agent runs one cycle and exits. Pair with the override
# above to bake a specific direction into history before the demo.
FORNEX_SINGLE_CYCLE=

# Drift devnet has a known SDK quirk: programmatic deposit() fails until the
# user account is bootstrapped via the Drift web UI. While bootstrapping is
# pending, set DRIFT_SKIP_EXECUTION=1 (default) to skip placePerpOrder calls
# and just write decisions on-chain with executed=false. After depositing
# USDC via https://app.drift.trade/?network=devnet, set this to 0.
DRIFT_SKIP_EXECUTION=1

# Pluggable executor adapter. Default is "synthetic" — the on-chain
# Pyth-marked synthetic perp executor that doesn't depend on any external
# dex. Set to "drift" to use the Drift Protocol adapter (gated additionally
# by DRIFT_SKIP_EXECUTION while Drift devnet is in maintenance).
FORNEX_EXECUTOR=synthetic

# Signal feed (read-only) — point at mainnet so agents see real Drift
# market data. Devnet Drift markets have ~0 volume which makes every
# decision default to FLAT. Trading and on-chain logging stay on devnet.
# Free public endpoint shown; switch to a paid RPC if you hit limits.
SIGNALS_RPC_URL=https://api.mainnet-beta.solana.com
SIGNALS_DRIFT_ENV=mainnet-beta
