# Solana Devnet Configuration
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CLUSTER=devnet

# ⚠ REQUIRED for /app data to load — public devnet RPC blocks getProgramAccounts
# Get your key: https://dev.helius.xyz/dashboard/app → API Keys → devnet RPC URL
# Format: https://devnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_HELIUS_RPC_URL=

# Program Addresses
NEXT_PUBLIC_VAULT_PROGRAM_ID=H6vbfTp6XwfFSHWtpzjZuyrx6bpnp8Rwt6bVZAUT6vZf
NEXT_PUBLIC_VAULT_ADDRESS=HMkL7zzAroE919esVY6HSMYzB2ejHM5m4A8JKCSrgBXR
NEXT_PUBLIC_FNRX_MINT=BNBf6ed4h8dZiVd8wpUkcv8BUyFsp75eidkcUhSb94vj

# Helius webhook live feed (set to true to enable SSE badge on frontend)
NEXT_PUBLIC_HELIUS_WEBHOOK_ENABLED=true

# Optional: Helius RPC for higher rate limits (leave blank to use public devnet)
# Do NOT commit a real Helius API key — set this in Vercel env vars only
NEXT_PUBLIC_HELIUS_RPC_URL=

